# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search (Stage 2)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key-here
AZURE_SEARCH_INDEX_NAME=filingsiq-index

# Multi-year pipeline index (Stage 5 — all 5 fiscal years; used by /ask with year filter)
AZURE_SEARCH_PIPELINE_INDEX_NAME=filingsiq-pipeline-index

# SEC EDGAR asks automated clients to identify themselves with contact information.
SEC_USER_AGENT=FilingsIQ/1.0 your-email@example.com

# Paid on-demand ingestion. Keep false on public deployments without authentication.
ENABLE_COMPANY_IMPORT=false

# Fine-tuned clause classifier deployment (Stage 4 — spin up for demos, delete after)
AZURE_FT_DEPLOYMENT_NAME=ft-cuad-classifier

# Azure AI Document Intelligence (Stage 3)
AZURE_DOCINTEL_ENDPOINT=https://your-docintel-resource.cognitiveservices.azure.com/
AZURE_DOCINTEL_KEY=your-docintel-key-here

# Azure AI Language (Stage 3)
AZURE_LANGUAGE_ENDPOINT=https://your-language-resource.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your-language-key-here
